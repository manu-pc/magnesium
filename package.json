{
  "name": "magnesium",
  "productName": "Magnesium",
  "version": "1.0.0",
  "description": "A fast, distraction-free Markdown editor for the desktop",
  "main": "./out/main/index.js",
  "author": {
    "name": "manu-pc",
    "email": "manu-pc@users.noreply.github.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/manu-pc/magnesium"
  },
  "homepage": "https://github.com/manu-pc/magnesium",
  "keywords": [
    "markdown",
    "editor",
    "electron",
    "desktop"
  ],
  "scripts": {
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "dist:linux": "electron-vite build && electron-builder --linux"
  },
  "build": {
    "appId": "com.manupc.magnesium",
    "productName": "Magnesium",
    "copyright": "Copyright © 2025 manu-pc",
    "publish": null,
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/"
      }
    ],
    "fileAssociations": [
      { "ext": "md",       "name": "Markdown Document", "mimeType": "text/markdown",            "role": "Editor" },
      { "ext": "markdown", "name": "Markdown Document", "mimeType": "text/markdown",            "role": "Editor" },
      { "ext": "txt",      "name": "Text File",         "mimeType": "text/plain",               "role": "Editor" },
      { "ext": "c",        "name": "C Source",          "mimeType": "text/x-csrc",              "role": "Editor" },
      { "ext": "h",        "name": "C Header",          "mimeType": "text/x-chdr",              "role": "Editor" },
      { "ext": "cpp",      "name": "C++ Source",        "mimeType": "text/x-c++src",            "role": "Editor" },
      { "ext": "cc",       "name": "C++ Source",        "mimeType": "text/x-c++src",            "role": "Editor" },
      { "ext": "cxx",      "name": "C++ Source",        "mimeType": "text/x-c++src",            "role": "Editor" },
      { "ext": "hpp",      "name": "C++ Header",        "mimeType": "text/x-c++hdr",            "role": "Editor" },
      { "ext": "java",     "name": "Java Source",       "mimeType": "text/x-java",              "role": "Editor" },
      { "ext": "py",       "name": "Python Script",     "mimeType": "text/x-python",            "role": "Editor" },
      { "ext": "html",     "name": "HTML Document",     "mimeType": "text/html",                "role": "Editor" },
      { "ext": "htm",      "name": "HTML Document",     "mimeType": "text/html",                "role": "Editor" },
      { "ext": "css",      "name": "CSS Stylesheet",    "mimeType": "text/css",                 "role": "Editor" },
      { "ext": "js",       "name": "JavaScript",        "mimeType": "application/javascript",   "role": "Editor" },
      { "ext": "ts",       "name": "TypeScript",        "mimeType": "application/typescript",   "role": "Editor" }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "icon": "resources/icons"
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1",
        "libsecret-1-0"
      ]
    }
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.1",
    "@codemirror/commands": "^6.6.0",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-markdown": "^6.2.5",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.10.2",
    "@codemirror/state": "^6.4.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.28.1",
    "codemirror": "^6.0.1",
    "electron-store": "^8.2.0",
    "highlight.js": "^11.9.0",
    "rehype-highlight": "^7.0.1",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  }
}
